# Configuration de l'application Dispatch Manager

# Flask
FLASK_APP=app.py
FLASK_ENV=production
# IMPORTANT: Changez cette clé en production! Générez avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecret_change_this_in_production_MANDATORY

# Base de données PostgreSQL
DB_TYPE=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dispatch
# IMPORTANT: Changez ces credentials en production!
POSTGRES_USER=dispatch_user
POSTGRES_PASSWORD=change_this_password_in_production_MANDATORY

# Base de données SQLite (legacy - non utilisé si DB_TYPE=postgresql)
DATABASE_PATH=dispatch.db

# Serveur
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Session
SESSION_LIFETIME_MINUTES=30
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# CSRF Protection
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=None

# File Upload
MAX_CONTENT_LENGTH=16777216

# Gunicorn
GUNICORN_WORKERS=4

# Nginx
NGINX_SERVER_NAME=localhost

# PDF Export (optionnel - chemin vers wkhtmltopdf)
# WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf
