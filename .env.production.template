# ========================================
# Configuration Production - Dispatch Manager
# ========================================
# Ce fichier est un TEMPLATE à copier sur le serveur
# Fichier cible: /opt/dispatch/.env
#
# IMPORTANT:
# - NE JAMAIS commiter ce fichier avec les vraies valeurs
# - Générer des secrets forts pour la production
# - Protéger le fichier: chmod 600 .env
#
# ========================================

# ========================================
# Flask Configuration
# ========================================
FLASK_APP=app.py
FLASK_ENV=production

# SECRET_KEY: Clé secrète pour signer les sessions et tokens CSRF
# Générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CARACTERES_ALEATOIRES_MINIMUM

# ========================================
# PostgreSQL Configuration
# ========================================
DB_TYPE=postgresql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dispatch
POSTGRES_USER=dispatch_user

# POSTGRES_PASSWORD: Mot de passe PostgreSQL fort
# Générer avec: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME_MOT_DE_PASSE_FORT_ALEATOIRE

# ========================================
# Connection Pooling
# ========================================
# Min: Nombre de connexions toujours disponibles
# Max: Nombre maximum de connexions simultanées
DB_POOL_MIN=5
DB_POOL_MAX=20

# ========================================
# Server Settings
# ========================================
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Nombre de workers Gunicorn (recommandé: 2-4 x CPU cores)
GUNICORN_WORKERS=4

# Taille maximale des fichiers uploadés (16MB par défaut)
MAX_CONTENT_LENGTH=16777216

# ========================================
# Security Settings
# ========================================
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=None

# Cookies sécurisés (HTTPS obligatoire)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Durée de vie des sessions en minutes (480 = 8 heures)
SESSION_LIFETIME_MINUTES=480

# ========================================
# Optional: Email Configuration (si notifications)
# ========================================
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=noreply@example.com
# MAIL_PASSWORD=CHANGE_ME
# MAIL_DEFAULT_SENDER=Dispatch <noreply@example.com>

# ========================================
# Optional: Sentry Error Tracking
# ========================================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ========================================
# Optional: Redis Cache (si implémenté)
# ========================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
