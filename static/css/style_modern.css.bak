/* ==============================
   DISPATCH MANAGER - CSS MODERNE V2.0
   Amélioration complète de l'UI
   ============================== */

:root {
  /* Palette claire */
  --primary: #4f46e5;
  --primary-hover: #4338ca;
  --secondary: #7c3aed;
  --success: #10b981;
  --danger: #ef4444;
  --warning: #f59e0b;
  --info: #3b82f6;
  
  /* Couleurs de fond */
  --bg-main: #f9fafb;
  --bg-card: #ffffff;
  --bg-hover: #f3f4f6;
  --bg-input: #ffffff;
  
  /* Textes */
  --text-primary: #111827;
  --text-secondary: #6b7280;
  --text-muted: #9ca3af;
  
  /* Bordures */
  --border-color: #e5e7eb;
  --border-radius: 12px;
  --border-radius-sm: 8px;
  
  /* Ombres */
  --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.1);
  --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
  
  /* Transitions */
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Mode sombre amélioré V2 - Meilleurs contrastes */
body.dark {
  --primary: #7c3aed;
  --primary-hover: #9333ea;
  --secondary: #a78bfa;
  --success: #22c55e;
  --danger: #ef4444;
  --warning: #f59e0b;
  --info: #3b82f6;
  
  --bg-main: #0f172a;
  --bg-card: #1e293b;
  --bg-hover: #334155;
  --bg-input: #1e293b;
  
  --text-primary: #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-muted: #94a3b8;
  
  --border-color: #334155;
  --shadow-sm: 0 1px 3px 0 rgb(0 0 0 / 0.4);
  --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.4);
  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.5);
}

/* ==============================
   STYLES GÉNÉRAUX
   ============================== */
   
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
  background: var(--bg-main);
  color: var(--text-primary);
  line-height: 1.6;
  transition: var(--transition);
  min-height: 100vh;
}

.container {
  max-width: 98%;
  width: 100%;
  margin: 0 auto;
  padding: 1.5rem;
}

/* ==============================
   NAVBAR MODERNE
   ============================== */
   
.navbar {
  background: var(--bg-card);
  border-radius: var(--border-radius);
  padding: 1rem 1.5rem;
  box-shadow: var(--shadow);
  margin-bottom: 2rem;
  border: 1px solid var(--border-color);
}

.navbar .container-fluid {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}

.navbar-brand {
  font-size: 1.25rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.025em;
}

/* ==============================
   SIDEBAR TECHNICIEN
   ============================== */
   
.sidebar {
  position: fixed;
  left: 0;
  top: 0;
  height: 100vh;
  width: 250px;
  background: var(--bg-card);
  border-right: 1px solid var(--border-color);
  box-shadow: var(--shadow);
  transform: translateX(-100%);
  transition: transform 0.3s ease;
  z-index: 1000;
  overflow-y: auto;
  padding: 1.5rem;
}

.sidebar.open {
  transform: translateX(0);
}

/* Sidebar permanente pour techniciens */
.sidebar-permanent {
  transform: translateX(0) !important;
}

.sidebar-toggle {
  position: fixed;
  left: 1rem;
  top: 1rem;
  z-index: 1001;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: var(--border-radius-sm);
  padding: 0.5rem 1rem;
  cursor: pointer;
  transition: var(--transition);
  display: none; /* Caché par défaut car sidebar toujours visible */
}

.sidebar-toggle:hover {
  background: var(--primary-hover);
  transform: scale(1.05);
}

.sidebar-header {
  margin-bottom: 2rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border-color);
}

.sidebar-header h3 {
  font-size: 1.125rem;
  font-weight: 600;
}

.sidebar-links {
  list-style: none;
  padding: 0;
}

.sidebar-links li {
  margin-bottom: 0.5rem;
}

.sidebar-links a {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  color: var(--text-primary);
  text-decoration: none;
  border-radius: var(--border-radius-sm);
  transition: var(--transition);
}

.sidebar-links a:hover {
  background: var(--bg-hover);
  color: var(--primary);
  transform: translateX(4px);
}

/* Liens désactivés (accès CHU uniquement) */
.sidebar-links a.disabled {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

/* Séparateur dans la sidebar */
.sidebar-divider {
  height: 1px;
  background: var(--border-color);
  margin: 1rem 0;
  list-style: none;
}

.sidebar-links .icon {
  width: 20px;
  height: 20px;
  opacity: 0.7;
}

body.with-sidebar .container {
  margin-left: 250px;
  transition: margin-left 0.3s ease;
}

body:not(.with-sidebar) .container {
  margin-left: 0;
}

/* Container avec sidebar permanente */
body.with-sidebar-permanent {
  padding-left: 270px;
}

body.with-sidebar-permanent .container {
  max-width: calc(98% - 270px);
  margin-left: 0;
}

body.with-sidebar-permanent .navbar {
  margin-left: 0;
}

body.with-sidebar-permanent h2,
body.with-sidebar-permanent .mb-3,
body.with-sidebar-permanent #incident-content {
  padding-left: 0;
}

/* ==============================
   BOUTONS MODERNES
   ============================== */
   
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.625rem 1.25rem;
  border-radius: var(--border-radius-sm);
  font-weight: 500;
  font-size: 0.875rem;
  transition: var(--transition);
  border: none;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
}

.btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.btn:active {
  transform: translateY(0);
}

.btn-primary {
  background: var(--primary);
  color: white;
}

.btn-primary:hover {
  background: var(--primary-hover);
}

.btn-secondary {
  background: var(--bg-hover);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
}

.btn-success {
  background: var(--success);
  color: white;
}

.btn-danger {
  background: var(--danger);
  color: white;
}

.btn-info {
  background: var(--info);
  color: white;
}

.btn-outline-danger {
  background: transparent;
  color: var(--danger);
  border: 1px solid var(--danger);
}

.btn-outline-danger:hover {
  background: var(--danger);
  color: white;
}

.btn-sm {
  padding: 0.375rem 0.75rem;
  font-size: 0.8rem;
}

/* ==============================
   CARTES MODERNES
   ============================== */
   
.card {
  background: var(--bg-card);
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  overflow: hidden;
  margin-bottom: 1rem;
}

.card:hover {
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}

.card-header {
  padding: 1rem 1.25rem;
  background: var(--bg-hover);
  border-bottom: 1px solid var(--border-color);
  font-weight: 600;
}

.card-body {
  padding: 1.25rem;
}

/* ==============================
   GRILLE TECHNICIENS RESPONSIVE
   ============================== */
   
#columnsView {
  width: 100%;
  overflow: visible;
}

.tech-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1rem;
  width: 100%;
}

.tech-column {
  min-width: 0;
  width: 100%;
}

.tech-column .card {
  height: 100%;
}

.tech-column .card-header {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: white;
  text-align: center;
  font-weight: 600;
}

/* ==============================
   INCIDENTS CARDS
   ============================== */
   
.incident-card-col {
  padding: 1rem;
  border-bottom: 1px solid var(--border-color);
  transition: var(--transition);
}

.incident-card-col:hover {
  background: var(--bg-hover);
}

.incident-card-col:last-child {
  border-bottom: none;
}

/* ==============================
   BADGES AMÉLIORÉS
   ============================== */
   
.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.75rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.025em;
}

/* ==============================
   INPUTS & SELECTS MODERNES
   ============================== */
   
.form-control,
.form-select {
  background: var(--bg-input);
  color: var(--text-primary);
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius-sm);
  padding: 0.625rem 1rem;
  font-size: 0.875rem;
  transition: var(--transition);
}

.form-control:focus,
.form-select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgb(79 70 229 / 0.1);
}

/* ==============================
   COMPTEURS STATS
   ============================== */
   
#statsCounters .card {
  transition: var(--transition);
  cursor: pointer;
}

#statsCounters .card:hover {
  transform: scale(1.05);
  box-shadow: var(--shadow-lg);
}

#statsCounters h3 {
  font-size: 2rem;
  font-weight: 700;
}

#statsCounters h6 {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* ==============================
   ANIMATIONS
   ============================== */
   
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.card {
  animation: slideIn 0.4s ease;
}

/* ==============================
   RESPONSIVE
   ============================== */
   
@media (max-width: 1024px) {
  .container {
    max-width: 95%;
  }
  
  .tech-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
}

@media (max-width: 768px) {
  .container {
    padding: 1rem;
  }
  
  .tech-grid {
    grid-template-columns: 1fr;
  }
  
  .sidebar {
    width: 100%;
  }
  
  body.with-sidebar .container {
    margin-left: 0;
  }
  
  /* Désactiver le padding de la sidebar permanente sur mobile */
  body.with-sidebar-permanent {
    padding-left: 0;
  }
  
  body.with-sidebar-permanent .container {
    max-width: 100%;
  }
  
  #statsCounters .col-md-3 {
    width: 50%;
  }
}

@media (max-width: 480px) {
  .navbar-brand {
    font-size: 1rem;
  }
  
  .btn {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }
  
  #statsCounters .col-md-3 {
    width: 100%;
  }
}

/* ==============================
   SCROLLBAR CUSTOM
   ============================== */
   
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-main);
}

::-webkit-scrollbar-thumb {
  background: var(--text-muted);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-secondary);
}

/* ==============================
   TOOLTIPS
   ============================== */
   
[title] {
  position: relative;
}

[title]:hover::after {
  content: attr(title);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  padding: 0.5rem 1rem;
  background: var(--text-primary);
  color: var(--bg-card);
  border-radius: var(--border-radius-sm);
  font-size: 0.75rem;
  white-space: nowrap;
  z-index: 1000;
  pointer-events: none;
}

/* ==============================
   LOADING STATES
   ============================== */
   
.loading {
  position: relative;
  pointer-events: none;
  opacity: 0.6;
}

.loading::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20px;
  height: 20px;
  margin: -10px 0 0 -10px;
  border: 2px solid var(--primary);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
